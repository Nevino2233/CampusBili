<div class="page-recommend">
  <section class="recommend-header">
    <h1 class="page-title">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" style="display:inline-block;vertical-align:middle;margin-right:8px;">
        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
      </svg>
      推荐视频
    </h1>
    <p class="page-subtitle">根据你的兴趣智能推荐</p>
  </section>

  <div class="recommend-mode-switch" id="recommendModeSwitch">
    <button class="recommend-mode-btn active" data-mode="personalized" id="modePersonalized">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="vertical-align:middle;margin-right:4px;">
        <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
      </svg>
      个性化推荐
    </button>
    <button class="recommend-mode-btn" data-mode="general" id="modeGeneral">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="vertical-align:middle;margin-right:4px;">
        <path d="M4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm16-4H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-1 9H9V9h10v2zm-4 4H9v-2h6v2zm4-8H9V5h10v2z"/>
      </svg>
      通用推荐
    </button>
  </div>

  <div class="recommend-personalized-section" id="personalizedSection">
    <% if (!isLoggedIn) { %>
    <div class="recommend-sessdata-panel" id="sessdataPanel">
      <div class="sessdata-panel-inner">
        <div class="sessdata-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </div>
        <h3 class="sessdata-title">个性化推荐需要登录验证</h3>
        <p class="sessdata-desc">输入你的 SESSDATA 以获取个性化推荐内容，数据仅在本地使用不会上传</p>
        <div class="sessdata-input-group">
          <input type="text" class="sessdata-input" id="sessdataInput" placeholder="请输入你的 SESSDATA" autocomplete="off" spellcheck="false">
          <button class="sessdata-submit-btn" id="sessdataSubmitBtn">获取推荐</button>
        </div>
        <div class="sessdata-hint">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="vertical-align:middle;margin-right:4px;">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
          </svg>
          SESSDATA 可从浏览器 Cookie 中获取，或 <a href="/auth/login">登录账号</a> 后自动使用
        </div>
        <div class="sessdata-error" id="sessdataError" style="display:none;"></div>
      </div>
    </div>
    <% } %>

    <div class="recommend-personalized-list" id="personalizedList" style="display:none;">
      <div class="recommend-list-header">
        <h2 class="recommend-list-title">为你推荐</h2>
        <button class="recommend-refresh-btn" id="refreshBtn" title="换一批">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/>
          </svg>
          换一批
        </button>
      </div>
      <div class="video-grid" id="personalizedGrid"></div>
      <div class="recommend-load-more" id="personalizedLoadMore" style="display:none;">
        <button class="load-more-btn" id="loadMorePersonalizedBtn">加载更多</button>
      </div>
    </div>

    <div class="recommend-personalized-loading" id="personalizedLoading" style="display:none;">
      <div class="loader-spinner"></div>
      <p>正在获取个性化推荐...</p>
    </div>

    <div class="recommend-personalized-empty" id="personalizedEmpty" style="display:none;">
      <div class="empty-state-illustration">
        <span class="empty-icon-large">&#128250;</span>
      </div>
      <p class="empty-state-text">暂无个性化推荐</p>
      <p class="empty-state-hint">请确认 SESSDATA 有效后重试</p>
    </div>
  </div>

  <div class="recommend-general-section" id="generalSection" style="display:none;">
    <% if (recommendVideos && recommendVideos.length > 0) { %>
    <div class="video-grid">
      <% recommendVideos.forEach(function(video) { %>
      <% var _coverUrl = (video.pic || ''); if (_coverUrl.indexOf('//') === 0 && _coverUrl.indexOf('http') !== 0) { _coverUrl = 'https:' + _coverUrl; } %>
      <a href="/video/<%= video.bvid %>" class="video-card">
        <div class="video-cover">
          <img
            src="<%= _coverUrl ? '/image/proxy?url=' + encodeURIComponent(_coverUrl) : '' %>"
            alt="<%= video.title %>"
            loading="lazy"
            onerror="this.onerror=null;this.src='data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAzMjAgMTgwIj48cmVjdCBmaWxsPSIjZWVlIiB3aWR0aD0iMzIwIiBoZWlnaHQ9IjE4MCIvPjx0ZXh0IHg9IjUwJSIgeT0iNTAlIiBkb21pbmFudC1iYXNlbGluZT0ibWlkZGxlIiB0ZXh0LWFuY2hvcj0ibWlkZGxlIiBmaWxsPSIjOTk5IiBmb250LXNpemU9IjE0Ij7nu6flg7o8L3RleHQ+PC9zdmc+'"
          >
          <div class="cover-overlay">
            <span class="cover-stat">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
                <path d="M4.5 3.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm0 12a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm8-9a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm0 6a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zM4 4v8m8-7v6"/>
              </svg>
              <%= formatCount(video.play || 0) %>
            </span>
            <span class="cover-stat">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
                <path d="M2 2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2zm2.5 0a.5.5 0 0 0-.5.5v10a.5.5 0 0 0 .5.5h7a.5.5 0 0 0 .5-.5v-10a.5.5 0 0 0-.5-.5h-7z"/>
              </svg>
              <%= formatCount(video.danmaku || 0) %>
            </span>
          </div>
          <% if (video.duration) { %>
          <span class="cover-duration"><%= formatDuration(video.duration) %></span>
          <% } %>
        </div>
        <div class="video-info">
          <h3 class="video-title"><%= video.title %></h3>
          <div class="video-meta">
            <span class="video-author"><%= video.author || '未知 UP 主' %></span>
            <div class="video-stats">
              <span><%= formatCount(video.play || 0) %> 播放</span>
            </div>
          </div>
        </div>
      </a>
      <% }); %>
    </div>
    <% } else { %>
    <div class="empty-state">
      <div class="empty-state-illustration">
        <span class="empty-icon-large">&#128250;</span>
      </div>
      <p class="empty-state-text">暂无推荐视频</p>
      <p class="empty-state-hint">请稍后再来查看</p>
      <a href="/" class="empty-state-action">返回首页</a>
    </div>
    <% } %>
  </div>
</div>

<script>
(function() {
  var isLoggedIn = <%= isLoggedIn ? 'true' : 'false' %>;
  var currentMode = 'personalized';
  var freshIdx = 1;
  var isLoading = false;
  var customSessdata = '';

  var modeSwitch = document.getElementById('recommendModeSwitch');
  var personalizedSection = document.getElementById('personalizedSection');
  var generalSection = document.getElementById('generalSection');
  var personalizedList = document.getElementById('personalizedList');
  var personalizedGrid = document.getElementById('personalizedGrid');
  var personalizedLoading = document.getElementById('personalizedLoading');
  var personalizedEmpty = document.getElementById('personalizedEmpty');
  var personalizedLoadMore = document.getElementById('personalizedLoadMore');
  var loadMoreBtn = document.getElementById('loadMorePersonalizedBtn');
  var refreshBtn = document.getElementById('refreshBtn');
  var sessdataPanel = document.getElementById('sessdataPanel');
  var sessdataInput = document.getElementById('sessdataInput');
  var sessdataSubmitBtn = document.getElementById('sessdataSubmitBtn');
  var sessdataError = document.getElementById('sessdataError');

  modeSwitch.addEventListener('click', function(e) {
    var btn = e.target.closest('.recommend-mode-btn');
    if (!btn) return;
    var mode = btn.getAttribute('data-mode');
    if (mode === currentMode) return;

    var btns = modeSwitch.querySelectorAll('.recommend-mode-btn');
    for (var i = 0; i < btns.length; i++) btns[i].classList.remove('active');
    btn.classList.add('active');

    currentMode = mode;
    if (mode === 'personalized') {
      personalizedSection.style.display = '';
      generalSection.style.display = 'none';
    } else {
      personalizedSection.style.display = 'none';
      generalSection.style.display = '';
    }
  });

  if (isLoggedIn) {
    loadPersonalized();
  }

  if (sessdataSubmitBtn) {
    sessdataSubmitBtn.addEventListener('click', function() {
      var val = sessdataInput.value.trim();
      if (!val) {
        showSessdataError('请输入 SESSDATA');
        return;
      }
      customSessdata = val;
      hideSessdataError();
      loadPersonalized();
    });

    sessdataInput.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') sessdataSubmitBtn.click();
    });
  }

  if (refreshBtn) {
    refreshBtn.addEventListener('click', function() {
      freshIdx = 1;
      personalizedGrid.innerHTML = '';
      loadPersonalized();
    });
  }

  if (loadMoreBtn) {
    loadMoreBtn.addEventListener('click', function() {
      if (!isLoading) loadPersonalized();
    });
  }

  function loadPersonalized() {
    if (isLoading) return;
    isLoading = true;

    if (personalizedList) personalizedList.style.display = 'none';
    if (personalizedEmpty) personalizedEmpty.style.display = 'none';
    if (personalizedLoading) personalizedLoading.style.display = '';
    if (personalizedLoadMore) personalizedLoadMore.style.display = 'none';

    var url = '/api/recommend/feed?ps=30&fresh_idx=' + freshIdx;

    var xhr = new XMLHttpRequest();
    xhr.open('GET', url, true);
    xhr.timeout = 15000;

    xhr.onload = function() {
      isLoading = false;
      if (personalizedLoading) personalizedLoading.style.display = 'none';

      if (xhr.status === 401) {
        if (customSessdata) {
          showSessdataError('SESSDATA 无效或已过期，请重新输入');
          if (sessdataPanel) sessdataPanel.style.display = '';
        }
        showPersonalizedEmpty();
        return;
      }

      try {
        var data = JSON.parse(xhr.responseText);
        if (data.code === 0 && data.data && data.data.items) {
          renderPersonalizedVideos(data.data.items);
          freshIdx++;
          if (personalizedLoadMore) personalizedLoadMore.style.display = '';
        } else {
          var msg = (data && data.message) ? data.message : '获取推荐失败';
          if (msg.indexOf('未登录') > -1 || msg.indexOf('登录') > -1) {
            if (sessdataPanel) sessdataPanel.style.display = '';
          }
          showPersonalizedEmpty();
        }
      } catch (e) {
        showPersonalizedEmpty();
      }
    };

    xhr.onerror = function() {
      isLoading = false;
      if (personalizedLoading) personalizedLoading.style.display = 'none';
      showPersonalizedEmpty();
    };

    xhr.ontimeout = function() {
      isLoading = false;
      if (personalizedLoading) personalizedLoading.style.display = 'none';
      showSessdataError('请求超时，请检查网络后重试');
      showPersonalizedEmpty();
    };

    xhr.send();
  }

  function renderPersonalizedVideos(items) {
    if (!items || items.length === 0) {
      showPersonalizedEmpty();
      return;
    }

    if (sessdataPanel) sessdataPanel.style.display = 'none';
    if (personalizedEmpty) personalizedEmpty.style.display = 'none';
    if (personalizedList) personalizedList.style.display = '';

    var fragment = document.createDocumentFragment();

    for (var i = 0; i < items.length; i++) {
      var item = items[i];
      var card = createPersonalizedCard(item);
      if (card) fragment.appendChild(card);
    }

    personalizedGrid.appendChild(fragment);
  }

  function createPersonalizedCard(item) {
    var coverUrl = item.pic || '';
    if (coverUrl.indexOf('//') === 0 && coverUrl.indexOf('http') !== 0) {
      coverUrl = 'https:' + coverUrl;
    }
    if (coverUrl.indexOf('http://') === 0) {
      coverUrl = 'https://' + coverUrl.substring(7);
    }

    var card = document.createElement('a');
    card.href = '/video/' + item.bvid;
    card.className = 'video-card recommend-card-personalized';

    var rcmdHtml = '';
    if (item.rcmd_reason) {
      rcmdHtml = '<span class="recommend-reason">' + escapeHtml(item.rcmd_reason) + '</span>';
    }

    var durationStr = '';
    if (item.duration) {
      durationStr = formatDuration(item.duration);
    }

    var coverDiv = document.createElement('div');
    coverDiv.className = 'video-cover';

    var img = document.createElement('img');
    img.alt = item.title || '';
    img.loading = 'lazy';
    if (coverUrl) {
      img.src = '/image/proxy?url=' + encodeURIComponent(coverUrl);
    }
    img.onerror = function() {
      this.onerror = null;
      this.src = 'data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAzMjAgMTgwIj48cmVjdCBmaWxsPSIjZWVlIiB3aWR0aD0iMzIwIiBoZWlnaHQ9IjE4MCIvPjx0ZXh0IHg9IjUwJSIgeT0iNTAlIiBkb21pbmFudC1iYXNlbGluZT0ibWlkZGxlIiB0ZXh0LWFuY2hvcj0ibWlkZGxlIiBmaWxsPSIjOTk5IiBmb250LXNpemU9IjE0Ij7nu6flg7o8L3RleHQ+PC9zdmc+';
      this.classList.add('loaded');
    };
    if (img.complete && img.naturalWidth > 0) {
      img.classList.add('loaded');
    } else {
      img.addEventListener('load', function() {
        this.classList.add('loaded');
      });
    }

    var overlayDiv = document.createElement('div');
    overlayDiv.className = 'cover-overlay';
    overlayDiv.innerHTML =
      '<span class="cover-stat">' +
        '<svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M4.5 3.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm0 12a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm8-9a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm0 6a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zM4 4v8m8-7v6"/></svg>' +
        formatCount(item.play || 0) +
      '</span>' +
      '<span class="cover-stat">' +
        '<svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M2 2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2zm2.5 0a.5.5 0 0 0-.5.5v10a.5.5 0 0 0 .5.5h7a.5.5 0 0 0 .5-.5v-10a.5.5 0 0 0-.5-.5h-7z"/></svg>' +
        formatCount(item.danmaku || 0) +
      '</span>';

    coverDiv.appendChild(img);
    coverDiv.appendChild(overlayDiv);

    if (durationStr) {
      var durationSpan = document.createElement('span');
      durationSpan.className = 'cover-duration';
      durationSpan.textContent = durationStr;
      coverDiv.appendChild(durationSpan);
    }

    var infoDiv = document.createElement('div');
    infoDiv.className = 'video-info';

    var infoHtml = '';
    if (rcmdHtml) {
      infoHtml += '<div class="recommend-reason-wrap">' + rcmdHtml + '</div>';
    }
    infoHtml += '<h3 class="video-title">' + escapeHtml(item.title) + '</h3>';
    infoHtml += '<div class="video-meta">' +
      '<span class="video-author">' +
        '<a href="/space/' + (item.mid || '') + '" onclick="event.stopPropagation();">' + escapeHtml(item.author || '未知UP主') + '</a>' +
      '</span>' +
      '<div class="video-stats">' +
        '<span>' + formatCount(item.play || 0) + ' 播放</span>' +
        '<span>&#x2764; ' + formatCount(item.like || 0) + '</span>' +
      '</div>' +
    '</div>';
    infoDiv.innerHTML = infoHtml;

    card.appendChild(coverDiv);
    card.appendChild(infoDiv);

    return card;
  }

  function showPersonalizedEmpty() {
    if (personalizedList) personalizedList.style.display = 'none';
    if (personalizedEmpty) personalizedEmpty.style.display = '';
  }

  function showSessdataError(msg) {
    if (sessdataError) {
      sessdataError.textContent = msg;
      sessdataError.style.display = '';
    }
  }

  function hideSessdataError() {
    if (sessdataError) sessdataError.style.display = 'none';
  }

  function formatCount(n) {
    n = parseInt(n) || 0;
    if (n >= 100000000) return (n / 100000000).toFixed(1) + '亿';
    if (n >= 10000) return (n / 10000).toFixed(1) + '万';
    return n.toString();
  }

  function formatDuration(seconds) {
    seconds = parseInt(seconds) || 0;
    var h = Math.floor(seconds / 3600);
    var m = Math.floor((seconds % 3600) / 60);
    var s = seconds % 60;
    if (h > 0) {
      return h + ':' + ('0' + m).slice(-2) + ':' + ('0' + s).slice(-2);
    }
    return ('0' + m).slice(-2) + ':' + ('0' + s).slice(-2);
  }

  function escapeHtml(text) {
    if (!text) return '';
    var div = document.createElement('div');
    div.appendChild(document.createTextNode(text));
    return div.innerHTML;
  }
})();
</script>
