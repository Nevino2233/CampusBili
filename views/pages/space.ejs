<div class="space-page">
  <% if (user) { %>
  <a href="javascript:history.back()" class="back-button" title="返回上一页">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    返回
  </a>
  <section class="space-header">
    <div class="space-banner" style="background: linear-gradient(135deg, #FB7299 0%, #e5658a 50%, #d9587b 100%);">
      <% if (user.top_photo) { %>
      <img src="/image/proxy?url=<%= encodeURIComponent(user.top_photo) %>" alt="" class="space-banner-img" onerror="this.style.display='none'">
      <% } %>
      <div class="space-banner-overlay"></div>
      <div class="space-profile">
        <div class="space-avatar-wrapper">
          <% var _faceUrl = (user.face || ''); if (_faceUrl.indexOf('//') === 0 && _faceUrl.indexOf('http') !== 0) { _faceUrl = 'https:' + _faceUrl; } %>
          <img src="<%= _faceUrl ? '/image/proxy?url=' + encodeURIComponent(_faceUrl) : '' %>" alt="<%= user.name %>" class="space-avatar" onerror="this.onerror=null;this.src='data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCA4MCA4MCI+PHJlY3QgZmlsbD0iI2VlZSIgd2lkdGg9IjgwIiBoZWlnaHQ9IjgwIi8+PHRleHQgeD0iNTAlIiB5PSI1MCUiIGRvbWluYW50LWJhc2VsaW5lPSJtaWRkbGUiIHRleHQtYW5jaG9yPSJtaWRkbGUiIGZpbGw9IiM5OTkiIGZvbnQtc2l6ZT0iMTQiPuWbvueJhDwvdGV4dD48L3N2Zz4='">
          <% if (user.level) { %>
          <span class="space-level">Lv.<%= user.level %></span>
          <% } %>
        </div>
        <div class="space-info">
          <h1 class="space-name">
            <%= user.name %>
            <% if (user.official && user.official.role && user.official.role > 0) { %>
            <span class="official-badge"><%= user.official.title || '认证' %></span>
            <% } %>
            <% if (user.vip && user.vip.status === 1) { %>
            <span class="vip-badge-large">大会员</span>
            <% } %>
          </h1>
          <% if (user.sign) { %>
          <p class="space-sign"><%= stripHtmlTags(user.sign) %></p>
          <% } %>
          <div class="space-stats">
            <% if (user.sex && user.sex !== '保密') { %>
            <span class="stat-item"><%= user.sex %></span>
            <span class="stat-divider">·</span>
            <% } %>
            <span class="stat-item">粉丝 <strong><%= formatCount(user.fans || 0) %></strong></span>
            <span class="stat-divider">·</span>
            <span class="stat-item">关注 <strong><%= formatCount(user.friend || 0) %></strong></span>
            <span class="stat-divider">·</span>
            <span class="stat-item">投稿 <strong><%= formatCount(user.archive_count || 0) %></strong></span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <nav class="space-tabs">
    <button class="tab-btn active">投稿视频 <span class="tab-count"><%= videos.length %></span></button>
  </nav>

  <section class="space-videos">
    <% if (videos.length > 0) { %>
    <div class="video-grid">
      <% videos.forEach(function(video) { %>
      <% var _coverUrl = (video.pic || ''); if (_coverUrl.indexOf('//') === 0 && _coverUrl.indexOf('http') !== 0) { _coverUrl = 'https:' + _coverUrl; } %>
      <a href="/video/<%= video.bvid %>" class="video-card">
        <div class="card-cover">
          <img src="<%= _coverUrl ? '/image/proxy?url=' + encodeURIComponent(_coverUrl) : '' %>" alt="<%= video.title %>" loading="lazy" onerror="this.onerror=null;this.src='data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAzMjAgMTgwIj48cmVjdCBmaWxsPSIjZWVlIiB3aWR0aD0iMzIwIiBoZWlnaHQ9IjE4MCIvPjx0ZXh0IHg9IjUwJSIgeT0iNTAlIiBkb21pbmFudC1iYXNlbGluZT0ibWlkZGxlIiB0ZXh0LWFuY2hvcj0ibWlkZGxlIiBmaWxsPSIjOTk5IiBmb250LXNpemU9IjE0Ij7nu6flg7o8L3RleHQ+PC9zdmc+'">
          <div class="cover-overlay">
            <span class="cover-stat">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M4.5 3.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm0 12a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm8-9a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm0 6a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zM4 4v8m8-7v6"/></svg>
              <%= formatCount(video.play || 0) %>
            </span>
            <span class="cover-stat">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M2 2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2zm2.5 0a.5.5 0 0 0-.5.5v10a.5.5 0 0 0 .5.5h7a.5.5 0 0 0 .5-.5v-10a.5.5 0 0 0-.5-.5h-7z"/></svg>
              <%= formatCount(video.danmaku || 0) %>
            </span>
          </div>
          <span class="card-duration"><%= video.length || video.duration || '' %></span>
        </div>
        <div class="card-info">
          <h3 class="card-title"><%= video.title %></h3>
          <div class="card-meta">
            <span><%= video.author || user.name %></span>
            <span><%= formatCount(video.play || 0) %> 播放</span>
          </div>
        </div>
      </a>
      <% }); %>
    </div>
    <% } else { %>
    <div class="empty-state">
      <div class="empty-state-illustration">
        <span class="empty-icon-large">&#127916;</span>
      </div>
      <p class="empty-state-text">该用户暂无投稿视频</p>
    </div>
    <% } %>
  </section>
  <% } else { %>
  <div class="empty-state">
    <div class="empty-state-illustration">
      <span class="empty-icon-large">&#128533;</span>
    </div>
    <p class="empty-state-text">无法加载用户信息</p>
    <p class="empty-state-hint">该用户可能不存在或已被封禁</p>
    <a href="/" class="back-link">返回首页</a>
  </div>
  <% } %>
</div>