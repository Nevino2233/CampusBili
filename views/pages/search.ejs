<div class="page-search">
  <!-- 搜索头部 -->
  <div class="search-header">
    <h2 class="search-keyword">搜索结果：<span class="keyword-highlight">"<%= keyword %>"</span></h2>
    <p class="search-count search-count-highlight">
      共找到约 <strong><%= numResults %></strong> 个结果
    </p>

    <!-- 搜索类型切换 -->
    <div class="search-type-tabs">
      <a href="/search?keyword=<%= encodeURIComponent(keyword) %>&search_type=video" class="search-type-tab <%= currentSearchType === 'video' ? 'active' : '' %>">视频</a>
      <a href="/search?keyword=<%= encodeURIComponent(keyword) %>&search_type=bili_user" class="search-type-tab <%= currentSearchType === 'bili_user' ? 'active' : '' %>">UP主</a>
    </div>

    <% if (currentSearchType === 'video' && searchResults && searchResults.length > 0) { %>
    <div class="search-sort-options">
      <span class="sort-label">排序：</span>
      <a href="/search?keyword=<%= encodeURIComponent(keyword) %>&search_type=video&order=totalrank" class="sort-option <%= (!order || order === 'totalrank') ? 'active' : '' %>">综合</a>
      <a href="/search?keyword=<%= encodeURIComponent(keyword) %>&search_type=video&order=click" class="sort-option <%= order === 'click' ? 'active' : '' %>">播放量</a>
      <a href="/search?keyword=<%= encodeURIComponent(keyword) %>&search_type=video&order=pubdate" class="sort-option <%= order === 'pubdate' ? 'active' : '' %>">最新发布</a>
      <a href="/search?keyword=<%= encodeURIComponent(keyword) %>&search_type=video&order=dm" class="sort-option <%= order === 'dm' ? 'active' : '' %>">弹幕数</a>
    </div>
    <% } %>
  </div>

  <!-- 搜索结果 -->
  <% if (currentSearchType === 'bili_user') { %>
  <% if (searchResults && searchResults.length > 0) { %>
  <div class="up-list">
    <% searchResults.forEach(function(result) { %>
    <% var _faceUrl = (result.upic || ''); if (_faceUrl.indexOf('//') === 0 && _faceUrl.indexOf('http') !== 0) { _faceUrl = 'https:' + _faceUrl; } %>
    <a href="/space/<%= result.mid %>" class="up-card">
      <div class="up-avatar">
        <img
          src="<%= _faceUrl ? '/image/proxy?url=' + encodeURIComponent(_faceUrl) : '' %>"
          alt="<%= result.uname || 'UP主' %>"
          onerror="this.onerror=null;this.src='data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCA4MCA4MCI+PHJlY3QgZmlsbD0iI2VlZSIgd2lkdGg9IjgwIiBoZWlnaHQ9IjgwIi8+PHRleHQgeD0iNTAlIiB5PSI1MCUiIGRvbWluYW50LWJhc2VsaW5lPSJtaWRkbGUiIHRleHQtYW5jaG9yPSJtaWRkbGUiIGZpbGw9IiM5OTkiIGZvbnQtc2l6ZT0iMTQiPuWbvueJhDwvdGV4dD48L3N2Zz4='"
        >
      </div>
      <div class="up-info">
        <h3 class="up-name"><%- typeof highlightKeyword !== 'undefined' ? highlightKeyword(result.uname || '未知UP主', keyword) : (result.uname || '未知UP主') %></h3>
        <p class="up-sign"><%= result.usign || '这个人很懒，什么都没写~' %></p>
        <div class="up-stats">
          <span class="up-stat">粉丝 <strong><%= formatCount(result.fans || 0) %></strong></span>
          <span class="up-stat">投稿 <strong><%= formatCount(result.videos || 0) %></strong></span>
        </div>
      </div>
    </a>
    <% }); %>
  </div>

  <!-- UP主搜索分页 -->
  <% if (total > 1) { %>
  <div class="pagination">
    <% if (currentPage > 1) { %>
    <a href="/search?keyword=<%= encodeURIComponent(keyword) %>&search_type=bili_user&page=<%= currentPage - 1 %>" class="page-btn">&lt; 上一页</a>
    <% } else { %>
    <span class="page-btn disabled">&lt; 上一页</span>
    <% } %>

    <span class="page-info">第 <%= currentPage %> 页 / 共 <%= total %> 页</span>

    <% if (currentPage < total) { %>
    <a href="/search?keyword=<%= encodeURIComponent(keyword) %>&search_type=bili_user&page=<%= currentPage + 1 %>" class="page-btn">下一页 &gt;</a>
    <% } else { %>
    <span class="page-btn disabled">下一页 &gt;</span>
    <% } %>
  </div>
  <% } %>
  <% } else { %>
  <div class="empty-state empty-state-search">
    <div class="empty-state-illustration">
      <span class="empty-icon-large">&#128100;</span>
    </div>
    <p class="empty-state-text">未找到相关UP主</p>
    <p class="empty-state-hint">请尝试使用其他关键词搜索</p>
  </div>
  <% } %>

  <% } else { %>
  <% if (searchResults && searchResults.length > 0) { %>
  <div class="video-grid search-result-grid">
    <% searchResults.forEach(function(result) { %>
    <% var _coverUrl = (result.pic || result.cover || ''); if (_coverUrl.indexOf('//') === 0 && _coverUrl.indexOf('http') !== 0) { _coverUrl = 'https:' + _coverUrl; } %>
    <a href="/video/<%= result.bvid %>" class="video-card search-result-card">
      <div class="video-cover search-cover">
        <img
          src="<%= _coverUrl ? '/image/proxy?url=' + encodeURIComponent(_coverUrl) : '' %>"
          alt="<%= (result.title || '').replace(/<[^>]*>/g, '') %>"
          loading="lazy"
          onerror="var el=this;el.onerror=null;el.style.cssText='background:#eee;display:flex;align-items:center;justify-content:center;font-size:12px;color:#999';el.alt='加载失败';el.src='data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAzMjAgMTgwIj48cmVjdCBmaWxsPSIjZWVlIiB3aWR0aD0iMzIwIiBoZWlnaHQ9IjE4MCIvPjx0ZXh0IHg9IjUwJSIgeT0iNTAlIiBkb21pbmFudC1iYXNlbGluZT0ibWlkZGxlIiB0ZXh0LWFuY2hvcj0ibWlkZGxlIiBmaWxsPSIjOTk5IiBmb250LXNpemU9IjE0Ij7nu6flg7o8L3RleHQ+PC9zdmc+'"
        >
        <% if (result.duration) { %>
        <span class="cover-duration"><%= result.duration %></span>
        <% } %>
        <div class="cover-overlay">
          <span class="cover-stat">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
              <path d="M4.5 3.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm0 12a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm8-9a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm0 6a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zM4 4v8m8-7v6"/>
            </svg>
            <%= formatCount(result.play || result.stat && result.stat.view ? result.play || result.stat.view : 0) %>
          </span>
          <span class="cover-stat">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
              <path d="M2 2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2zm2.5 0a.5.5 0 0 0-.5.5v10a.5.5 0 0 0 .5.5h7a.5.5 0 0 0 .5-.5v-10a.5.5 0 0 0-.5-.5h-7z"/>
            </svg>
            <%= formatCount(result.video_review || result.stat && result.stat.danmaku ? result.video_review || result.stat.danmaku : 0) %>
          </span>
        </div>
      </div>
      <div class="video-info">
        <h3 class="video-title search-result-title"><%- typeof highlightKeyword !== 'undefined' ? highlightKeyword(result.title, keyword) : sanitizeTitle(result.title) %></h3>
        <div class="video-meta">
          <span class="video-author"><%= result.author || result.owner && result.owner.name ? result.author || result.owner.name : '未知UP主' %></span>
          <div class="video-stats">
            <span><%= formatCount(result.play || result.stat && result.stat.view ? result.play || result.stat.view : 0) %> 播放</span>
          </div>
        </div>
      </div>
    </a>
    <% }); %>
  </div>

  <!-- 视频搜索分页 -->
  <% if (total > 1) { %>
  <div class="pagination">
    <% if (currentPage > 1) { %>
    <a href="/search?keyword=<%= encodeURIComponent(keyword) %>&search_type=video&page=<%= currentPage - 1 %>" class="page-btn">&lt; 上一页</a>
    <% } else { %>
    <span class="page-btn disabled">&lt; 上一页</span>
    <% } %>

    <span class="page-info">第 <%= currentPage %> 页 / 共 <%= total %> 页</span>

    <% if (currentPage < total) { %>
    <a href="/search?keyword=<%= encodeURIComponent(keyword) %>&search_type=video&page=<%= currentPage + 1 %>" class="page-btn">下一页 &gt;</a>
    <% } else { %>
    <span class="page-btn disabled">下一页 &gt;</span>
    <% } %>
  </div>
  <% } %>
  <% } else { %>
  <div class="empty-state empty-state-search">
    <div class="empty-state-illustration">
      <span class="empty-icon-large">&#128269;</span>
    </div>
    <p class="empty-state-text">未找到相关结果</p>
    <p class="empty-state-hint">请尝试使用其他关键词搜索</p>
    <div class="suggested-keywords">
      <span class="suggested-label">推荐搜索：</span>
      <a href="/search?keyword=动画" class="suggested-tag">动画</a>
      <a href="/search?keyword=音乐" class="suggested-tag">音乐</a>
      <a href="/search?keyword=游戏" class="suggested-tag">游戏</a>
      <a href="/search?keyword=科技" class="suggested-tag">科技</a>
      <a href="/search?keyword=生活" class="suggested-tag">生活</a>
    </div>
  </div>
  <% } %>
  <% } %>
</div>