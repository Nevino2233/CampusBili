<div class="page-ranking">
  <!-- 刷新按钮 -->
  <div class="ranking-header">
    <button class="refresh-ranking-btn" onclick="location.reload()" title="刷新排行榜">
      &#8635; 刷新榜单
    </button>
  </div>

  <!-- 排行榜标签 -->
  <div class="ranking-tabs ranking-tabs-animated">
    <a href="/ranking?rid=0" data-rid="0" class="ranking-tab <%= currentRid === '0' ? 'active' : '' %>">全站</a>
    <a href="/ranking?rid=1" data-rid="1" class="ranking-tab <%= currentRid === '1' ? 'active' : '' %>">动画</a>
    <a href="/ranking?rid=3" data-rid="3" class="ranking-tab <%= currentRid === '3' ? 'active' : '' %>">音乐</a>
    <a href="/ranking?rid=129" data-rid="129" class="ranking-tab <%= currentRid === '129' ? 'active' : '' %>">舞蹈</a>
    <a href="/ranking?rid=4" data-rid="4" class="ranking-tab <%= currentRid === '4' ? 'active' : '' %>">游戏</a>
    <a href="/ranking?rid=36" data-rid="36" class="ranking-tab <%= currentRid === '36' ? 'active' : '' %>">知识</a>
    <a href="/ranking?rid=188" data-rid="188" class="ranking-tab <%= currentRid === '188' ? 'active' : '' %>">科技</a>
    <a href="/ranking?rid=234" data-rid="234" class="ranking-tab <%= currentRid === '234' ? 'active' : '' %>">运动</a>
    <a href="/ranking?rid=223" data-rid="223" class="ranking-tab <%= currentRid === '223' ? 'active' : '' %>">汽车</a>
    <a href="/ranking?rid=160" data-rid="160" class="ranking-tab <%= currentRid === '160' ? 'active' : '' %>">生活</a>
    <a href="/ranking?rid=138" data-rid="138" class="ranking-tab <%= currentRid === '138' ? 'active' : '' %>">搞笑</a>
    <a href="/ranking?rid=211" data-rid="211" class="ranking-tab <%= currentRid === '211' ? 'active' : '' %>">美食</a>
    <a href="/ranking?rid=217" data-rid="217" class="ranking-tab <%= currentRid === '217' ? 'active' : '' %>">动物圈</a>
    <a href="/ranking?rid=119" data-rid="119" class="ranking-tab <%= currentRid === '119' ? 'active' : '' %>">鬼畜</a>
    <a href="/ranking?rid=155" data-rid="155" class="ranking-tab <%= currentRid === '155' ? 'active' : '' %>">时尚</a>
    <a href="/ranking?rid=5" data-rid="5" class="ranking-tab <%= currentRid === '5' ? 'active' : '' %>">娱乐</a>
    <a href="/ranking?rid=181" data-rid="181" class="ranking-tab <%= currentRid === '181' ? 'active' : '' %>">影视</a>
  </div>

  <!-- 排行榜列表 -->
  <% if (rankingList && rankingList.length > 0) { %>
  <div class="ranking-list">
    <% rankingList.forEach(function(item, index) { %>
    <a href="/video/<%= item.bvid %>" class="ranking-item<%= index < 3 ? ' ranking-top-' + (index + 1) : '' %>">
      <div class="ranking-rank <%= index < 3 ? 'top-' + (index + 1) : 'normal' %>">
        <%= (currentPage - 1) * 20 + index + 1 %>
      </div>
      <div class="ranking-cover">
        <img
          src="/image/proxy?url=<%= encodeURIComponent(item.pic) %>"
          alt="<%= item.title %>"
          loading="lazy"
          onerror="this.onerror=null;this.src='data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAzMjAgMTgwIj48cmVjdCBmaWxsPSIjZWVlIiB3aWR0aD0iMzIwIiBoZWlnaHQ9IjE4MCIvPjx0ZXh0IHg9IjUwJSIgeT0iNTAlIiBkb21pbmFudC1iYXNlbGluZT0ibWlkZGxlIiB0ZXh0LWFuY2hvcj0ibWlkZGxlIiBmaWxsPSIjOTk5IiBmb250LXNpemU9IjE0Ij7nu6flg7o8L3RleHQ+PC9zdmc+'"
        >
        <% if (item.duration) { %>
        <span class="cover-duration"><%= formatDuration(item.duration) %></span>
        <% } %>
      </div>
      <div class="ranking-info">
        <h4 class="ranking-title"><%= item.title %></h4>
        <div class="ranking-details">
          <span><%= formatCount(item.stat && item.stat.view ? item.stat.view : 0) %> 播放</span>
          <span><%= item.owner && item.owner.name ? item.owner.name : '未知UP主' %></span>
        </div>
      </div>
    </a>
    <% }); %>
  </div>

  <!-- 分页提示 -->
  <% if (total === 100) { %>
  <div class="pagination-hint">
    <span class="page-info">显示前 100 名视频</span>
  </div>
  <% } %>
  <% } else { %>
  <div class="empty-state">
    <div class="empty-state-icon">&#128196;</div>
    <p class="empty-state-text">暂无排行榜数据</p>
    <p class="empty-state-hint">请稍后再试或切换其他分区</p>
  </div>
  <% } %>
</div>
